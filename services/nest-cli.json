{
  "monorepo": true,
  "root": "api-gateway",
  "sourceRoot": "api-gateway/src",
  "compilerOptions": {
    "webpack": false,
    "tsConfigPath": "api-gateway/tsconfig.app.json",
    "deleteOutDir": true
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "api-gateway",
      "sourceRoot": "api-gateway/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "api-gateway/tsconfig.app.json"
      }
    },
    "content-service": {
      "type": "application",
      "root": "content-service",
      "sourceRoot": "content-service/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "content-service/tsconfig.app.json"
      }
    },
    "exam-service": {
      "type": "application",
      "root": "exam-service",
      "sourceRoot": "exam-service/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "exam-service/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "sourceRoot": "libs/contracts/src",
      "entryFile": "index",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "sourceRoot": "libs/common/src",
      "entryFile": "index",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "prisma": {
      "type": "library",
      "root": "libs/prisma",
      "sourceRoot": "libs/prisma/src",
      "entryFile": "index",
      "compilerOptions": {
        "tsConfigPath": "libs/prisma/tsconfig.lib.json"
      }
    }
  }
}
