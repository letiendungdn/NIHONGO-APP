{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@edu/vocab-images": ["../packages/vocab-images/src"],
      "@prisma/client": ["../packages/prisma-nihongo/generated/client"],
      "@prisma/client/*": ["../packages/prisma-nihongo/generated/client/*"],
      "@app/common": ["../packages/nest-common/src"],
      "@app/common/*": ["../packages/nest-common/src/*"],
      "@app/prisma": ["../packages/nest-prisma/src"],
      "@app/prisma/*": ["../packages/nest-prisma/src/*"],
      "@app/contracts": ["../packages/nest-contracts/src"],
      "@app/contracts/*": ["../packages/nest-contracts/src/*"]
    }
  }
}
